{
    "include": [
        "**/*",
        "**/.server/**/*",
        "**/.client/**/*",
        ".react-router/types/**/*",
        "app/routes/public/lost/lost.tsx"
    ],
    "compilerOptions": {
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "types": ["node", "vite/client"],
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "rootDirs": [".", "./.react-router/types"],
        "baseUrl": ".",
        "paths": {
            "~commons/*": ["./app/component/common/*"],
            "~icons/*": ["./app/component/icons/*"],
            "~section/*": ["./app/component/section/*"],
            "~component/*": ["./app/component/*"],
            "~constant/*": ["./app/core/constant/*"],
            "~service/*": ["./app/core/service/*"],
            "~helper/*": ["./app/core/helper/*"],
            "~hook/*": ["./app/core/hook/*"],
            "~api/*": ["./app/core/api/*"],
            "~type/*": ["./app/core/type/*"],
            "~/*": ["./app/*"]
        },
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true
    }
}
